{{#if dataIsLoaded}}
  {{#if securityEnabled}}
    <div>
      <span class="text-success">{{t admin.security.enabled}}</span>
      {{#isAuthorized "CLUSTER.TOGGLE_KERBEROS"}}
        {{#if App.supports.enableToggleKerberos}}
          <button href="#" {{action showManageOIDCCredentialsPopup target="controller"}}
            class="btn btn-default pull-right">
            {{t admin.oidc.button.manageCredentials}}
          </button>
          <button href="#" {{action runOidcProvisioning target="controller"}}
            class="btn btn-default pull-right mrm">
            {{t admin.oidc.button.runProvisioning}}
          </button>
          <button href="#" {{action makeConfigsEditable target="controller"}}
            {{bindAttr class="controller.isEditMode:hidden :btn :btn-default :pull-right :mrm"}}>
            {{t common.edit}}
          </button>
        {{/if}}
      {{/isAuthorized}}
    </div>
    <div id="serviceConfig">
      {{view App.ServicesConfigView}}
    </div>
    <div {{bindAttr class=":btn-area :pull-right controller.isEditMode::hidden"}}>
      <button id="cancel-oidc-reconfigure" {{action makeConfigsUneditable target="controller"}}
              class="btn btn-default">{{t common.cancel}}</button>
      <button id="save-oidc-reconfigure"
              class="btn btn-success" {{bindAttr disabled="isSaveButtonDisabled"}}
        {{action submit target="controller"}}>{{t common.save}}</button>
    </div>
  {{else}}
    <div>
      <p class="muted background-text">{{t admin.security.disabled}}
        {{#isAuthorized "CLUSTER.TOGGLE_KERBEROS"}}
          {{#if App.supports.enableToggleKerberos}}
            <a class="btn btn-padding btn-success admin-enable-security-btn" {{action checkAndStartKerberosWizard target="controller"}}>{{t admin.oidc.button.enableSecurity}} </a>
            <a class="btn btn-padding btn-default admin-enable-security-btn" {{action showManageOIDCCredentialsPopup target="controller"}}>{{t admin.oidc.button.manageCredentials}} </a>
            <br/>
          {{/if}}
        {{/isAuthorized}}
      </p>
    </div>
  {{/if}}
{{else}}
  {{view App.SpinnerView}}
{{/if}}
