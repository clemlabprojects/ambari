{{#if dataIsLoaded}}
  {{#if securityEnabled}}
    <div>
      <span class="text-success">{{t admin.security.enabled}}</span>
      {{#isAuthorized "CLUSTER.TOGGLE_KERBEROS"}}
        {{#if App.supports.enableToggleKerberos}}
          <button href="#" {{action showManageOIDCCredentialsPopup target="controller"}}
            class="btn btn-success" {{bindAttr disabled="controller.isKerberosButtonsDisabled"}}>
            {{t admin.oidc.button.manageCredentials}}
          </button>
          <button href="#" {{action runOidcProvisioning target="controller"}}
            class="btn btn-success" {{bindAttr disabled="controller.isKerberosButtonsDisabled"}}>
            {{t admin.oidc.button.runProvisioning}}
          </button>
          <br/>
          <button href="#" {{action makeConfigsEditable target="controller"}}
            {{bindAttr class="controller.isEditMode:hidden :btn :btn-default :pull-right"}}>
            {{t common.edit}}
          </button>
        {{/if}}
      {{/isAuthorized}}
    </div>
    <div id="serviceConfig">
      {{view App.ServicesConfigView}}
    </div>
    <div {{bindAttr class=":btn-area :pull-right controller.isEditMode::hidden"}}>
      <button id="cancel-oidc-reconfigure" {{action makeConfigsUneditable target="controller"}}
              class="btn btn-default">{{t common.cancel}}</button>
      <button id="save-oidc-reconfigure"
              class="btn btn-success" {{bindAttr disabled="isSaveButtonDisabled"}}
        {{action submit target="controller"}}>{{t common.save}}</button>
    </div>
  {{else}}
    <div>
      <p class="muted background-text">{{t admin.security.disabled}}
        {{#isAuthorized "CLUSTER.TOGGLE_KERBEROS"}}
          {{#if App.supports.enableToggleKerberos}}
            <a class="btn btn-padding btn-success admin-enable-security-btn" {{action checkAndStartKerberosWizard target="controller"}}>{{t admin.oidc.button.enableSecurity}} </a>
            <a class="btn btn-padding btn-success admin-enable-security-btn" {{action showManageOIDCCredentialsPopup target="controller"}}>{{t admin.oidc.button.manageCredentials}} </a>
            <br/>
          {{/if}}
        {{/isAuthorized}}
      </p>
    </div>
  {{/if}}

  <div class="oidc-clients-section" style="margin-top:24px;">
    <h4>{{t admin.oidc.clients.title}}</h4>
    {{#if controller.oidcClientsContent.length}}
      <table class="table table-striped table-bordered table-hover" id="oidc-clients-table">
        <thead>
          <tr>
            <th>{{t admin.oidc.clients.table.service}}</th>
            <th>{{t admin.oidc.clients.table.clientName}}</th>
            <th>{{t admin.oidc.clients.table.clientId}}</th>
            <th>{{t admin.oidc.clients.table.realm}}</th>
            <th>{{t admin.oidc.clients.table.enabled}}</th>
            <th>{{t admin.oidc.clients.table.mappers}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each client in controller.oidcClientsContent}}
            <tr>
              <td>{{client.serviceName}}</td>
              <td>{{client.name}}</td>
              <td><code>{{client.clientId}}</code></td>
              <td>{{client.realm}}</td>
              <td>
                {{#if client.enabled}}
                  <span class="label label-success">{{t common.yes}}</span>
                {{else}}
                  <span class="label label-default">{{t common.no}}</span>
                {{/if}}
              </td>
              <td>
                {{#if client.protocolMappers.length}}
                  <a href="#" {{action showProtocolMappersPopup client target="controller"}}>
                    {{t admin.oidc.clients.table.viewMappers}} ({{client.protocolMappers.length}})
                  </a>
                {{else}}
                  <span class="muted">—</span>
                {{/if}}
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <p class="muted">{{t admin.oidc.clients.noClients}}</p>
    {{/if}}
  </div>
{{else}}
  {{view App.SpinnerView}}
{{/if}}
