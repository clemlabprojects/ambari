<upgrade-config-changes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="upgrade-config.xsd">
  <services>

    <service name="ZOOKEEPER">
      <component name="ZOOKEEPER_SERVER">
        <changes>
          <definition xsi:type="configure" id="odp_1_2_4_0_zookeeper_client_zk_server">
            <type>zookeeper-log4j</type>
            <set key="zookeeper_log_level" value="INFO"/>
          </definition>
        </changes>
      </component>
    </service>

    <service name="HDFS">
      <component name="NAMENODE">
        <changes>
          <definition xsi:type="configure" id="odp_1_2_4_0_zookeeper_client_hdfs">
            <type>hadoop-env</type>
            <set key="hdfs.zookeeper.log.level" value="ERROR"/>
          </definition>
        </changes>
      </component>
    </service>
    <service name="KAFKA">
      <component name="KAFKA_BROKER">
        <changes>
          <definition xsi:type="configure" id="odp_1_2_4_0_kafka_3_broker_transaction">
            <type>kafka-broker</type>
            <set key="transaction.state.log.min.isr" value="2"/>
            <set key="transaction.state.log.replication.factor" value="3"/>
          </definition>
          <definition xsi:type="configure" id="odp_1_3_2_0_kafka_pin_protocol_3_8" summary="Pin Kafka IBP=3.8 so 3.9 brokers stay wire-compatible with not-yet-restarted 3.8 brokers during the rolling restart.">
            <type>kafka-broker</type>
            <set key="inter.broker.protocol.version" value="3.8"/>
          </definition>
          <definition xsi:type="configure" id="odp_1_3_2_0_kafka_bump_protocol_3_9" summary="Bump Kafka IBP to 3.9 (point of no return: ODP/Kafka downgrade impossible after the next broker restart per Apache Kafka 3.9 docs).">
            <type>kafka-broker</type>
            <set key="inter.broker.protocol.version" value="3.9"/>
          </definition>
        </changes>
      </component>
    </service>
    <service name="TEZ">
      <component name="TEZ_CLIENT">
        <changes>
           <definition xsi:type="configure" id="odp_1_2_4_0_tez_harmonizegc_option" summary="Harmonize GC option trough task and am">
            <type>tez-site</type>
            <replace  key="tez.am.launch.cmd-opts"   find="-XX:+UseParallelGC" replace-with="-XX:+UseG1GC"/>
            <replace  key="tez.task.launch.cmd-opts" find="-XX:+UseParallelGC" replace-with="-XX:+UseG1GC"/>
          </definition>
          <definition xsi:type="configure" id="odp_1_3_2_0_tez_view_ats_v15" summary="Enable ATSV15HistoryLoggingService for Tez View DAG/vertex detail">
            <type>tez-site</type>
            <set key="yarn.timeline-service.enabled" value="true"/>
            <set key="tez.am.history.logging.enabled" value="true"/>
            <set key="tez.history.logging.service.class" value="org.apache.tez.dag.history.logging.ats.ATSV15HistoryLoggingService"/>
            <set key="tez.runtime.convert.user-payload.to.history-text" value="true"/>
          </definition>
        </changes>
      </component>
    </service>

    <service name="YARN">
      <component name="APP_TIMELINE_SERVER">
        <changes>
          <definition xsi:type="configure" id="odp_1_3_2_0_yarn_ats_v15_tez_plugin" summary="Wire ATS v1.5 EntityGroupFSTimelineStore + Tez plugin for Tez View">
            <type>yarn-site</type>
            <set key="yarn.timeline-service.enabled" value="true"/>
            <set key="yarn.timeline-service.store-class" value="org.apache.hadoop.yarn.server.timeline.EntityGroupFSTimelineStore"/>
            <!-- Append the Tez ATS plugin to the existing plugin-classes list (idempotent: skipped if already present). -->
            <insert key="yarn.timeline-service.entity-group-fs-store.group-id-plugin-classes"
                    value=",org.apache.tez.dag.history.logging.ats.TimelineCachePluginImpl"
                    insert-type="append" newline-before="false" newline-after="false"/>
            <!-- group-id-plugin-classpath default is empty on pre-1.3.2.0 clusters; <set> overwrites unconditionally. -->
            <set key="yarn.timeline-service.entity-group-fs-store.group-id-plugin-classpath"
                 value="/usr/odp/current/tez-client/*:/usr/odp/current/tez-client/lib/*"/>
          </definition>
        </changes>
      </component>
    </service>
             
    <service name="HBASE">
      <component name="HBASE_MASTER">
        <changes>
          <definition xsi:type="configure" id="odp_1_2_4_0_zookeeper_client_log4j_hbase">
            <type>hbase-env</type>
            <set key="hbase.zookeeper.log.level" value="INFO"/>
          </definition>
          <definition xsi:type="configure" id="odp_1_3_2_0_create_hbase_log4j2_config">
            <type>hbase-log4j2</type>
          </definition>
          <definition xsi:type="configure" id="odp_1_2_4_0_support_hbase_thrift">
            <type>hbase-site</type>
            <set key="hbase.thrift.minWorkerThreads" value="200"/>
            <set key="hbase.thrift.info.port" value="9095"/>
            <set key="hbase.thrift.support.proxyuser" value="true"/>
            <set key="hbase.thrift.info.bindAddress" value="0.0.0.0"/>
            <set key="hbase.thrift.security.qop" value="auth-conf"/>
            <set key="hbase.thrift.ssl.enabled" value="false"/>
            <set key="hbase.thrift.ssl.keystore.store" value=""/>
            <set key="hbase.thrift.ssl.keystore.password" value=""/>
            <set key="hbase.thrift.ssl.keystore.keypassword" value=""/>
            <set key="hbase.thrift.ssl.keystore.type" value="JKS"/>
            <set key="hadoop.security.credential.provider.path" value="localjceks://file//etc/hbase/conf/creds.localjceks"/>
          </definition>
          <definition xsi:type="configure" id="odp_1_2_4_0_kafka_3_support_hbase_producer">
            <type>hbase-atlas-application-properties</type>
            <set key="atlas.kafka.enable.idempotence" value="false"/>
          </definition>
        </changes>
      </component>
    </service>

    <service name="HIVE">
      <component name="HIVE_SERVER">
        <changes>
          <definition xsi:type="configure" id="odp_1_2_4_0_zookeeper_client_log4j_hive">
            <type>hive-env</type>
            <set key="hive.zookeeper.log.level" value="INFO"/>
          </definition>
          <definition xsi:type="configure" id="odp_1_2_4_0_kafka_3_support_hive_producer">
            <type>hive-atlas-application.properties</type>
            <set key="atlas.kafka.enable.idempotence" value="false"/>
          </definition>
        </changes>
      </component>
    </service>

    <service name="ATLAS">
      <component name="ATLAS_SERVER">
        <changes>
          <definition xsi:type="configure" id="odp_1_2_4_0_kafka_3_support_atlas_consumer_producer">
            <type>application-properties</type>
            <set key="atlas.kafka.enable.idempotence" value="false"/>
          </definition>
          <definition xsi:type="configure" id="odp_1_2_4_0_kafka_3_kafka_client_log4j_atlas">
            <type>atlas-env</type>
            <set key="atlas.kafka.client.log.level" value="WARN"/>
          </definition>
          <definition xsi:type="configure" id="odp_1_3_2_0_atlas_logback_metadata_opts_migration">
            <type>atlas-env</type>
            <replace key="metadata_opts" find="-Dlog4j.configuration=atlas-log4j.xml" replace-with="-Dlogback.configurationFile=/etc/atlas/conf/atlas-logback.xml"/>
          </definition>
          <definition xsi:type="configure" id="odp_1_3_2_0_atlas_logback_metadata_opts_default">
            <type>atlas-env</type>
            <set key="metadata_opts" value="-Dlogback.configurationFile=/etc/atlas/conf/atlas-logback.xml" if-key="metadata_opts" if-key-state="absent"/>
          </definition>
          <definition xsi:type="configure" id="odp_1_3_2_0_atlas_openmetadata_federation_props"
                      summary="Add openmetadata.federation.{username,password_hash,role} placeholders to atlas-env so KDPS Atlas-federation provisioning can populate them on demand.">
            <type>atlas-env</type>
            <set key="openmetadata.federation.username" value="" if-key="openmetadata.federation.username" if-key-state="absent"/>
            <set key="openmetadata.federation.password_hash" value="" if-key="openmetadata.federation.password_hash" if-key-state="absent"/>
            <set key="openmetadata.federation.role" value="ROLE_USER" if-key="openmetadata.federation.role" if-key-state="absent"/>
          </definition>
        </changes>
      </component>
    </service>

    <service name="SPARK3">
      <component name="SPARK3_CLIENT">
        <changes>
          <definition xsi:type="configure" id="odp_1_3_0_spark3_atlas_hook_default_flag">
            <type>spark3-env</type>
            <set key="spark.atlas.hook" value="false" if-key="spark.atlas.hook" if-key-state="absent"/>
          </definition>
          <definition xsi:type="configure" id="odp_1_3_0_spark3_thrift_builtin_hive_metastore">
            <type>spark3-thrift-sparkconf</type>
            <transfer operation="delete" delete-key="spark.sql.hive.metastore.version"
                      if-key="spark.sql.hive.metastore.jars"
                      if-type="spark3-thrift-sparkconf"
                      if-value="/usr/odp/current/spark3-client/standalone-metastore/*"/>
            <set key="spark.sql.hive.metastore.jars" value="builtin"
                 if-key="spark.sql.hive.metastore.jars"
                 if-type="spark3-thrift-sparkconf"
                 if-value="/usr/odp/current/spark3-client/standalone-metastore/*"/>
          </definition>
          <!-- spark3-atlas-application.properties only exists on clusters that had ODP 1.2 SPARK3
               with Atlas integration enabled. ConfigureAction skips this step gracefully when
               the config type is absent, so clusters without Atlas are not blocked. -->
          <definition xsi:type="configure" id="odp_1_3_0_spark3_atlas_hook_configs">
            <type>spark3-atlas-application.properties</type>
            <set key="atlas.jaas.ticketBased-KafkaClient.loginModuleControlFlag" value="required"/>
            <set key="atlas.jaas.ticketBased-KafkaClient.loginModuleName" value="com.sun.security.auth.module.Krb5LoginModule"/>
            <set key="atlas.jaas.ticketBased-KafkaClient.option.useTicketCache" value="true"/>
          </definition>
        </changes>
      </component>
    </service>

  </services>
</upgrade-config-changes>
