{
  "IMPALA": {
    "service": [],
    "IMPALA_CATALOG_SERVICE": [
      {
        "name": "impala_catalog_health",
        "label": "Catalogd Health",
        "description": "This host-level alert is triggered if the catalogd health endpoint is unreachable.",
        "interval": 1,
        "scope": "HOST",
        "source": {
          "type": "WEB",
          "uri": {
            "http": "localhost:{{impala-env/impala_catalog_webserver_port}}/healthz",
            "https": "localhost:{{impala-env/impala_catalog_webserver_port}}/healthz",
            "https_property": "{{impala-env/client_services_ssl_enabled}}",
            "https_property_value": "true",
            "connection_timeout": 5.0
          },
          "reporting": {
            "ok": {
              "text": "HTTP {0} response in {2:.3f}s"
            },
            "warning": {
              "text": "HTTP {0} response from {1} in {2:.3f}s ({3})"
            },
            "critical": {
              "text": "Connection failed to {1} ({3})"
            }
          }
        }
      },
      {
        "name": "impala_catalog_rpc_port",
        "label": "Catalogd RPC Port",
        "description": "This host-level alert is triggered if the catalogd RPC listener is unreachable.",
        "interval": 1,
        "scope": "HOST",
        "source": {
          "type": "PORT",
          "uri": "{{impala-env/impala_catalog_service_port}}",
          "default_port": 26000,
          "reporting": {
            "ok": {
              "text": "TCP OK - {0:.3f}s response on port {1}"
            },
            "warning": {
              "text": "TCP OK - {0:.3f}s response on port {1}",
              "value": 1.5
            },
            "critical": {
              "text": "Connection failed: {0} to {1}:{2}",
              "value": 5.0
            }
          }
        }
      }
    ],
