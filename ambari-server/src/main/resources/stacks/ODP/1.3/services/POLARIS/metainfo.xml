<metainfo>
  <schemaVersion>2.0</schemaVersion>
  <services>
    <service>
      <name>POLARIS</name>
      <displayName>Polaris</displayName>
      <comment>Apache Polaris catalog service</comment>
      <version>1.1.0</version>

      <components>
        <component>
          <name>POLARIS_SERVER</name>
          <displayName>Polaris Server</displayName>
          <category>MASTER</category>
          <cardinality>1+</cardinality>
          <javaHomeSelector>secondary_java_home</javaHomeSelector>
          <versionAdvertised>false</versionAdvertised>
          <dependencies>
            <dependency>
              <name>OZONE/OZONE_CLIENT</name>
              <scope>host</scope>
              <auto-deploy>
                <enabled>true</enabled>
              </auto-deploy>
            </dependency>
          </dependencies>
          <commandScript>
            <script>scripts/polaris_server.py</script>
            <scriptType>PYTHON</scriptType>
            <timeout>600</timeout>
          </commandScript>
          <logs>
            <log>
              <logId>polaris_server</logId>
              <primary>true</primary>
            </log>
          </logs>
          <customCommands>
            <customCommand>
              <name>BOOTSTRAP_OZONE_CATALOG</name>
              <commandScript>
                <script>scripts/polaris_server.py</script>
                <scriptType>PYTHON</scriptType>
                <timeout>900</timeout>
              </commandScript>
            </customCommand>
          </customCommands>
        </component>

        <component>
          <name>POLARIS_CLIENT</name>
          <displayName>Polaris Client</displayName>
          <category>CLIENT</category>
          <cardinality>0+</cardinality>
          <javaHomeSelector>secondary_java_home</javaHomeSelector>
          <versionAdvertised>false</versionAdvertised>
          <dependencies>
            <dependency>
              <name>OZONE/OZONE_CLIENT</name>
              <scope>host</scope>
              <auto-deploy>
                <enabled>true</enabled>
              </auto-deploy>
            </dependency>
          </dependencies>
          <commandScript>
            <script>scripts/polaris_client.py</script>
            <scriptType>PYTHON</scriptType>
          </commandScript>
          <customCommands>
            <customCommand>
              <name>TOOLS_SMOKE_CHECK</name>
              <commandScript>
                <script>scripts/polaris_client.py</script>
                <scriptType>PYTHON</scriptType>
                <timeout>300</timeout>
              </commandScript>
            </customCommand>
          </customCommands>
          <configFiles>
            <configFile>
              <type>properties</type>
              <fileName>application.properties</fileName>
              <dictionaryName>polaris-application-properties</dictionaryName>
            </configFile>
            <configFile>
              <type>env</type>
              <fileName>logging.properties</fileName>
              <dictionaryName>polaris-logging-properties</dictionaryName>
            </configFile>
            <configFile>
              <type>env</type>
              <fileName>polaris-env.sh</fileName>
              <dictionaryName>polaris-env</dictionaryName>
            </configFile>
          </configFiles>
        </component>

        <component>
          <name>POLARIS_MCP_SERVER</name>
          <displayName>Polaris MCP Server</displayName>
          <category>MASTER</category>
          <cardinality>0+</cardinality>
          <javaHomeSelector>secondary_java_home</javaHomeSelector>
          <versionAdvertised>false</versionAdvertised>
          <dependencies>
            <dependency>
              <name>OZONE/OZONE_CLIENT</name>
              <scope>host</scope>
              <auto-deploy>
                <enabled>true</enabled>
              </auto-deploy>
            </dependency>
          </dependencies>
          <commandScript>
            <script>scripts/polaris_mcp_server.py</script>
            <scriptType>PYTHON</scriptType>
            <timeout>600</timeout>
          </commandScript>
          <logs>
            <log>
              <logId>polaris_mcp_server</logId>
              <primary>true</primary>
            </log>
          </logs>
        </component>

        <component>
          <name>POLARIS_CONSOLE</name>
          <displayName>Polaris Console</displayName>
          <category>MASTER</category>
          <cardinality>0+</cardinality>
          <javaHomeSelector>secondary_java_home</javaHomeSelector>
          <versionAdvertised>false</versionAdvertised>
          <dependencies>
            <dependency>
              <name>OZONE/OZONE_CLIENT</name>
              <scope>host</scope>
              <auto-deploy>
                <enabled>true</enabled>
              </auto-deploy>
            </dependency>
          </dependencies>
          <commandScript>
            <script>scripts/polaris_console.py</script>
            <scriptType>PYTHON</scriptType>
            <timeout>600</timeout>
          </commandScript>
          <logs>
            <log>
              <logId>polaris_console</logId>
              <primary>true</primary>
            </log>
          </logs>
        </component>
      </components>

      <osSpecifics>
        <osSpecific>
          <osFamily>redhat8,redhat9,redhat7,amazonlinux2,redhat6,suse11,suse12</osFamily>
          <packages>
            <package>
              <name>polaris_${stack_version}</name>
            </package>
            <package>
              <name>polaris_${stack_version}-tools</name>
            </package>
          </packages>
        </osSpecific>
        <osSpecific>
          <osFamily>debian7,debian9,ubuntu12,ubuntu14,ubuntu16,ubuntu22,ubuntu24</osFamily>
          <packages>
            <package>
              <name>polaris-${stack_version}</name>
            </package>
            <package>
              <name>polaris-tools-${stack_version}</name>
            </package>
          </packages>
        </osSpecific>
      </osSpecifics>

      <commandScript>
        <script>scripts/service_check.py</script>
        <scriptType>PYTHON</scriptType>
        <timeout>300</timeout>
      </commandScript>

      <requiredServices>
        <service>CORE</service>
      </requiredServices>

      <configuration-dependencies>
        <config-type>polaris-application-properties</config-type>
        <config-type>polaris-logging-properties</config-type>
        <config-type>polaris-db-properties</config-type>
        <config-type>polaris-env</config-type>
        <config-type>polaris-jaas-conf</config-type>
        <config-type>ranger-polaris-plugin-properties</config-type>
        <config-type>ranger-polaris-audit</config-type>
        <config-type>ranger-polaris-security</config-type>
        <config-type>ranger-polaris-policymgr-ssl</config-type>
      </configuration-dependencies>

      <themes>
        <theme>
          <fileName>theme_version_1.json</fileName>
          <default>true</default>
        </theme>
        <theme>
          <fileName>database.json</fileName>
          <default>true</default>
        </theme>
      </themes>

      <quickLinksConfigurations>
        <quickLinksConfiguration>
          <fileName>quicklinks.json</fileName>
          <default>true</default>
        </quickLinksConfiguration>
      </quickLinksConfigurations>

    </service>
  </services>
</metainfo>
