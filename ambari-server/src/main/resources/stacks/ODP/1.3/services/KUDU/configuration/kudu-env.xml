<?xml version="1.0"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>

<configuration supports_final="true" supports_do_not_extend="true">
  <property>
    <name>kudu_user</name>
    <display-name>Kudu User</display-name>
    <value>kudu</value>
    <property-type>USER</property-type>
    <description>Kudu service user.</description>
    <on-ambari-upgrade add="true"/>
  </property>
  <property>
    <name>kudu_group</name>
    <display-name>Kudu Group</display-name>
    <value>kudu</value>
    <property-type>GROUP</property-type>
    <description>Kudu service group.</description>
    <on-ambari-upgrade add="true"/>
  </property>
  <property>
    <name>kudu_conf_dir</name>
    <value>/etc/kudu/conf</value>
    <description>Kudu configuration directory.</description>
    <on-ambari-upgrade add="true"/>
  </property>
  <property>
    <name>kudu_log_dir</name>
    <value>/var/log/kudu</value>
    <description>Kudu log directory.</description>
    <on-ambari-upgrade add="true"/>
  </property>
  <property>
    <name>kudu_run_dir</name>
    <value>/var/run/kudu</value>
    <description>Kudu pid directory.</description>
    <on-ambari-upgrade add="true"/>
  </property>
  <property>
    <name>ranger_kudu_receiver_fifo_dir</name>
    <display-name>Ranger Receiver FIFO Directory</display-name>
    <value>/var/run/kudu</value>
    <description>Writable directory used by Kudu to create Ranger receiver FIFOs.</description>
    <on-ambari-upgrade add="true"/>
  </property>
  <property>
    <name>kudu_enable_tls</name>
    <display-name>Enable TLS</display-name>
    <value>false</value>
    <description>Enable TLS for Kudu RPC and web UI endpoints.</description>
    <value-attributes>
      <type>value-list</type>
      <entries>
        <entry>
          <value>true</value>
          <label>ON</label>
        </entry>
        <entry>
          <value>false</value>
          <label>OFF</label>
        </entry>
      </entries>
      <selection-cardinality>1</selection-cardinality>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>
  <property>
    <name>kudu_tls_cert_file</name>
    <value>/etc/kudu/conf/tls/kudu-server.crt</value>
    <description>PEM certificate used for Kudu TLS when enabled.</description>
    <on-ambari-upgrade add="true"/>
  </property>
  <property>
    <name>kudu_tls_private_key_file</name>
    <value>/etc/kudu/conf/tls/kudu-server.key</value>
    <description>PEM private key used for Kudu TLS when enabled.</description>
    <on-ambari-upgrade add="true"/>
  </property>
  <property>
    <name>kudu_tls_ca_cert_file</name>
    <value></value>
    <description>Optional CA certificate bundle for verifying TLS peers.</description>
    <value-attributes>
      <empty-value-valid>true</empty-value-valid>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>
  <property>
    <name>kudu_principal_name</name>
    <value>kudu/_HOST@EXAMPLE.COM</value>
    <description>Kudu Kerberos principal used when cluster security is enabled.</description>
    <on-ambari-upgrade add="true"/>
  </property>
  <property>
    <name>kudu_keytab</name>
    <value>/etc/security/keytabs/kudu.service.keytab</value>
    <description>Kudu keytab path used when cluster security is enabled.</description>
    <on-ambari-upgrade add="true"/>
  </property>
</configuration>
