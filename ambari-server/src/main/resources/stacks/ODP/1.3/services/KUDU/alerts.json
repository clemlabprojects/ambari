{
  "KUDU": {
    "service": [
      {
        "name": "kudu_tserver_process_percent",
        "label": "Percent Kudu TServers Available",
        "description": "This service-level alert is triggered if Kudu tablet server processes are unavailable.",
        "interval": 1,
        "scope": "SERVICE",
        "enabled": true,
        "source": {
          "type": "AGGREGATE",
          "alert_name": "kudu_tserver_process",
          "reporting": {
            "ok": {
              "text": "affected: [{1}], total: [{0}]"
            },
            "warning": {
              "text": "affected: [{1}], total: [{0}]",
              "value": 35
            },
            "critical": {
              "text": "affected: [{1}], total: [{0}]",
              "value": 70
            },
            "units": "%",
            "type": "PERCENT"
          }
        }
      }
    ],
    "KUDU_MASTER": [
      {
        "name": "kudu_master_process",
        "label": "Kudu Master Process",
        "description": "This host-level alert is triggered if the Kudu master process cannot be determined to be up.",
        "interval": 1,
        "scope": "HOST",
        "source": {
          "type": "PORT",
          "uri": "7051",
          "default_port": 7051,
          "reporting": {
            "ok": {
              "text": "TCP OK - {0:.3f}s response on port {1}"
            },
            "warning": {
              "text": "TCP OK - {0:.3f}s response on port {1}",
              "value": 1.5
            },
            "critical": {
              "text": "Connection failed: {0} to {1}:{2}",
              "value": 5.0
            }
          }
        }
      }
    ],
    "KUDU_TSERVER": [
      {
        "name": "kudu_tserver_process",
        "label": "Kudu Tablet Server Process",
        "description": "This host-level alert is triggered if the Kudu tablet server process cannot be determined to be up.",
        "interval": 1,
        "scope": "HOST",
        "source": {
          "type": "PORT",
          "uri": "7050",
          "default_port": 7050,
          "reporting": {
            "ok": {
              "text": "TCP OK - {0:.3f}s response on port {1}"
            },
            "warning": {
              "text": "TCP OK - {0:.3f}s response on port {1}",
              "value": 1.5
            },
            "critical": {
              "text": "Connection failed: {0} to {1}:{2}",
              "value": 5.0
            }
          }
        }
      }
    ]
  }
}
