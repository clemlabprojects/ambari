{
  "name": "default",
  "description": "default quick links configuration",
  "configuration": {
    "protocol": {
      "type": "HTTP_AND_HTTPS"
    },
    "links": [
      {
        "name": "kudu master web ui",
        "label": "KUDU MASTER WEB UI",
        "component_name": "KUDU_MASTER",
        "requires_user_name": "false",
        "url": "%@://%@:%@",
        "port": {
          "http_property": "webserver_port",
          "http_default_port": "8051",
          "https_property": "webserver_port",
          "https_default_port": "8051",
          "regex": "^(\\d+)$",
          "site": "kudu-master-env"
        }
      },
      {
        "name": "kudu tserver web ui",
        "label": "KUDU TSERVER WEB UI",
        "component_name": "KUDU_TSERVER",
        "requires_user_name": "false",
        "url": "%@://%@:%@",
        "port": {
          "http_property": "webserver_port",
          "http_default_port": "8050",
          "https_property": "webserver_port",
          "https_default_port": "8050",
          "regex": "^(\\d+)$",
          "site": "kudu-tserver-env"
        }
      }
    ]
  }
}
