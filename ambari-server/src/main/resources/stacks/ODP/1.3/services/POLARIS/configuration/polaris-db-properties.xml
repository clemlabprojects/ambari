<configuration supports_final="false">
  <property>
    <name>DB_FLAVOR</name>
    <value>POSTGRES</value>
    <display-name>Polaris DB Flavor</display-name>
    <description>Database flavor used by Polaris relational persistence.</description>
    <value-attributes>
      <overridable>false</overridable>
      <type>value-list</type>
      <entries>
        <entry>
          <value>POSTGRES</value>
          <label>POSTGRES</label>
        </entry>
      </entries>
      <selection-cardinality>1</selection-cardinality>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>db_host</name>
    <value>localhost</value>
    <display-name>Polaris DB Host</display-name>
    <description>Hostname (or host:port) of the PostgreSQL server.</description>
    <value-attributes>
      <overridable>false</overridable>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>db_port</name>
    <value>5432</value>
    <display-name>Polaris DB Port</display-name>
    <description>PostgreSQL server port.</description>
    <value-attributes>
      <type>int</type>
      <minimum>1</minimum>
      <maximum>65535</maximum>
      <overridable>false</overridable>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>db_name</name>
    <value>polaris</value>
    <display-name>Polaris DB Name</display-name>
    <description>Database name for Polaris metadata.</description>
    <value-attributes>
      <overridable>false</overridable>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>db_user</name>
    <value>polaris</value>
    <display-name>Polaris DB Username</display-name>
    <description>Database username for Polaris metadata access.</description>
    <value-attributes>
      <overridable>false</overridable>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property require-input="true">
    <name>db_password</name>
    <value/>
    <property-type>PASSWORD</property-type>
    <display-name>Polaris DB Password</display-name>
    <description>Database password for Polaris metadata access.</description>
    <value-attributes>
      <type>password</type>
      <overridable>false</overridable>
      <empty-value-valid>true</empty-value-valid>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>
</configuration>
