<?xml version="1.0"?>
<metainfo>
  <schemaVersion>2.0</schemaVersion>
  <services>
    <service>
      <name>KUDU</name>
      <displayName>Kudu</displayName>
      <comment>Apache Kudu distributed storage for fast analytics on rapidly changing data</comment>
      <version>1.18.1</version>
      <components>
        <component>
          <name>KUDU_MASTER</name>
          <displayName>Kudu Master</displayName>
          <category>MASTER</category>
          <cardinality>1+</cardinality>
          <commandScript>
            <script>scripts/kudu-master.py</script>
            <scriptType>PYTHON</scriptType>
            <timeout>10000</timeout>
          </commandScript>
        </component>
        <component>
          <name>KUDU_TSERVER</name>
          <displayName>Kudu Tablet Server</displayName>
          <category>SLAVE</category>
          <cardinality>1+</cardinality>
          <commandScript>
            <script>scripts/kudu-tserver.py</script>
            <scriptType>PYTHON</scriptType>
            <timeout>10000</timeout>
          </commandScript>
        </component>
        <component>
          <name>KUDU_CLIENT</name>
          <displayName>Kudu Client</displayName>
          <category>CLIENT</category>
          <cardinality>1+</cardinality>
          <commandScript>
            <script>scripts/kudu-client.py</script>
            <scriptType>PYTHON</scriptType>
            <timeout>10000</timeout>
          </commandScript>
        </component>
      </components>

      <osSpecifics>
        <osSpecific>
          <osFamily>redhat7,amazonlinux2,redhat6,suse11,suse12,redhat8,redhat9</osFamily>
          <packages>
            <package>
              <name>kudu_${stack_version}</name>
            </package>
            <package>
              <name>ranger-kudu-plugin</name>
            </package>
          </packages>
        </osSpecific>
        <osSpecific>
          <osFamily>ubuntu18,ubuntu20,ubuntu22,ubuntu24</osFamily>
          <packages>
            <package>
              <name>kudu_${stack_version}</name>
            </package>
            <package>
              <name>ranger-kudu-plugin</name>
            </package>
          </packages>
        </osSpecific>
      </osSpecifics>

      <configuration-dependencies>
        <config-type>kudu-env</config-type>
        <config-type>kudu-master-env</config-type>
        <config-type>kudu-tserver-env</config-type>
        <config-type>ranger-kudu-plugin-properties</config-type>
        <config-type>ranger-kudu-audit</config-type>
        <config-type>ranger-kudu-security</config-type>
        <config-type>ranger-kudu-policymgr-ssl</config-type>
      </configuration-dependencies>

      <quickLinksConfigurations>
        <quickLinksConfiguration>
          <fileName>quicklinks.json</fileName>
          <default>true</default>
        </quickLinksConfiguration>
      </quickLinksConfigurations>

      <restartRequiredAfterChange>true</restartRequiredAfterChange>
    </service>
  </services>
</metainfo>
