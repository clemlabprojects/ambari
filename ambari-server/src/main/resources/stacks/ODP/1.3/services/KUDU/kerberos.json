{
  "services": [
    {
      "name": "KUDU",
      "identities": [
        {
          "name": "kudu_service",
          "principal": {
            "value": "${kudu-env/kudu_user}/_HOST@${realm}",
            "type": "service",
            "configuration": "kudu-env/kudu_principal_name"
          },
          "keytab": {
            "file": "${keytab_dir}/kudu.service.keytab",
            "owner": {
              "name": "${kudu-env/kudu_user}",
              "access": "r"
            },
            "group": {
              "name": "${kudu-env/kudu_group}",
              "access": ""
            },
            "configuration": "kudu-env/kudu_keytab"
          }
        }
      ]
    }
  ]
}
