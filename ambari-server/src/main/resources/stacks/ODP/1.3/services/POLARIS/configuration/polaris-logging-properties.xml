<configuration supports_adding_forbidden="true">
  <property>
    <name>content</name>
    <display-name>polaris logging.properties template</display-name>
    <description>Additional Quarkus logging categories for Polaris. Use quoted category names when they contain dots.</description>
    <value>
# Additional Quarkus logging categories for Polaris.
# Example:
# quarkus.log.category."org.apache.polaris.extension.auth.ranger".level=DEBUG
# quarkus.log.category."org.apache.ranger.plugin.util.PolicyRefresher".level=DEBUG
# quarkus.log.category."org.apache.ranger.admin.client.RangerAdminRESTClient".level=DEBUG
    </value>
    <value-attributes>
      <type>content</type>
      <show-property-name>false</show-property-name>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>
</configuration>
