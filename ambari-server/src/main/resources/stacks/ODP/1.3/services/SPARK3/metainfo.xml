<metainfo>
  <schemaVersion>2.0</schemaVersion>
  <services>
    <service>
      <name>SPARK3</name>
      <version>3.5.4</version>
      <components>
        <!-- ODP 1.3.2.0 (AMBARI-491): Spark is built against Hive 4.2 (class-file 65) and must
             run the secondary JDK 21. The javaHomeSelector points params.py at secondary_java_home;
             gated at runtime by the secondary_java_home_support stack feature. -->
        <component>
          <name>SPARK3_JOBHISTORYSERVER</name>
          <javaHomeSelector>secondary_java_home</javaHomeSelector>
        </component>
        <component>
          <name>SPARK3_THRIFTSERVER</name>
          <javaHomeSelector>secondary_java_home</javaHomeSelector>
        </component>
        <component>
          <name>SPARK3_CLIENT</name>
          <javaHomeSelector>secondary_java_home</javaHomeSelector>
        </component>
        <component>
          <name>LIVY2_SERVER</name>
          <javaHomeSelector>secondary_java_home</javaHomeSelector>
        </component>
      </components>
    </service>
  </services>
</metainfo>
