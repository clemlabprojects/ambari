IMPALA_CATALOG_ARGS=" \
    -log_dir=${IMPALA_LOG_DIR} \
    -hostname={{current_host_name}} \
    -state_store_host=${IMPALA_STATE_STORE_HOST} \
    -catalog_service_host=${IMPALA_CATALOG_SERVICE_HOST} \
    -num_metadata_loading_threads={{impala_env['num_metadata_loading_threads']}} \
    -inc_stats_size_limit_bytes={{impala_env['inc_stats_size_limit_bytes']}} \
    -datastream_sender_timeout_ms={{impala_env['datastream_sender_timeout_ms']}} \
    -rpc_negotiation_thread_count={{impala_env['rpc_negotiation_thread_count']}} \
    -accepted_cnxn_queue_depth={{impala_env['accepted_cnxn_queue_depth']}} \
    -minidump_path={{impala_env['minidump_path']}} \
    -default_query_options={{impala_env['default_query_options']}} \
    -idle_query_timeout={{impala_env['impala_idle_query_timeout']}} \
    -idle_session_timeout={{impala_env['impala_idle_session_timeout']}} \
    -statestore_subscriber_timeout_seconds={{impala_env['statestore_subscriber_timeout_s']}} \
    {% if enable_catalogd_ha %}
    -enable_catalogd_ha=true \
    {% endif %}
    {% if enable_statestored_ha %}
    -enable_statestored_ha=true \
    -state_store_2_host={{impala_secondary_state_store_host}} \
    -state_store_2_port={{impala_env['impala_state_store_port']}} \
    {% endif %}
    -load_catalog_in_background={{impala_env['load_catalog_in_background']}} \
    -load_auth_to_local_rules={{impala_env['load_auth_to_local_rules']}} \
    -enable_legacy_avx_support={{impala_env['enable_legacy_avx_support']}} \
    -redaction_rules_file={{impala_env['redaction_rules_file']}} \
    {% if enable_ranger %}
    -server_name=${HIVE_SERVER_HOST} \
    -ranger_service_type=${RANGER_SERVICE_TYPE} \
    -ranger_app_id=${RANGER_APP_ID} \
    -authorization_provider=${AUTH_PROVIDER} \
    -authorized_proxy_user_config=${PROXY_USER_CONF} \
    {% endif %}
    -disable_kudu=true \
    {% if security_enabled %}
    -kerberos_reinit_interval=${KRB_REINIT_INT} \
    -principal=impala/{{impala_catalog_host}}@{{realm_name}} \
    -keytab_file=/etc/security/keytabs/impala.service.keytab \
    {% endif %}
    {% if client_services_ssl_enabled %}
    -ssl_server_certificate={{impala_env['ssl_server_certificate']}} \
    -ssl_private_key={{impala_env['ssl_private_key']}} \
    -ssl_private_key_password_cmd=${SSL_PRIVATE_KEY_PWD_CMD} \
    -ssl_client_ca_certificate={{impala_env['ssl_client_ca_certificate']}} \
    -webserver_certificate_file=${WEBSERVER_CERT_FILE} \
    -webserver_private_key_file=${WEBSERVER_PRIVATE_KEY_FILE} \
    -webserver_private_key_password_cmd=${WEBSERVER_PRIVATE_KEY_PWD_CMD} \
    {% endif %}
    {% if enable_ldap_auth %}
    -enable_ldap_auth=true \
    -ldap_uri=${LDAP_URI} \
    -ldap_passwords_in_clear_ok=${PWD_IN_CLEAR} \
    -ldap_domain=${LDAP_DOMAIN} \
    -ldap_bind_password_cmd=${BIND_PASSWORD} \
    {% endif %}
    {% if enable_ldap_tls %}
    -ldap_tls=true \
    -ldap_ca_certificate=${LDAP_CA_CERT} \
    {% endif %}
	"
