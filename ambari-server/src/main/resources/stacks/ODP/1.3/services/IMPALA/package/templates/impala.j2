KRB_REINIT_INT={{impala_env['kerberos_reinit_interval']}}
LOCAL_TO_UNIX={{impala_env['impala_use_local_tz_for_unix_timestamp_conversions']}}
LEGACY_HIVE_TS={{impala_env['impala_convert_legacy_hive_parquet_utc_timestamps']}}
