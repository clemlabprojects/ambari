<configuration supports_adding_forbidden="true">
  <property>
    <name>oidc_provider</name>
    <display-name>OIDC Provider</display-name>
    <value>keycloak</value>
    <description>OIDC provider implementation.</description>
    <value-attributes>
      <type>value-list</type>
      <entries>
        <entry>
          <value>keycloak</value>
          <label>Keycloak</label>
        </entry>
      </entries>
      <selection-cardinality>1</selection-cardinality>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>oidc_admin_url</name>
    <display-name>OIDC Admin URL</display-name>
    <value>http://localhost:8080</value>
    <description>Base URL for the OIDC admin endpoint.</description>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>oidc_admin_realm</name>
    <display-name>OIDC Admin Realm</display-name>
    <value>master</value>
    <description>Admin realm for the OIDC provider.</description>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>oidc_realm</name>
    <display-name>OIDC Realm</display-name>
    <value>odp</value>
    <description>Default OIDC realm used for service clients.</description>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>oidc_admin_client_id</name>
    <display-name>OIDC Admin Client ID</display-name>
    <value>admin-cli</value>
    <description>OIDC admin client id used to authenticate admin API calls.</description>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>oidc_admin_client_secret</name>
    <display-name>OIDC Admin Client Secret</display-name>
    <value></value>
    <description>OIDC admin client secret (if required by the provider).</description>
    <value-attributes>
      <type>password</type>
      <overridable>false</overridable>
      <empty-value-valid>true</empty-value-valid>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>oidc_verify_tls</name>
    <display-name>Verify TLS</display-name>
    <value>true</value>
    <description>Verify TLS certificates for OIDC admin API calls.</description>
    <value-attributes>
      <type>boolean</type>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>
</configuration>
