<view>
    <name>SQL-ASSISTANT-VIEW</name>
    <label>SQL Assistant</label>
    <version>1.0.0.0</version>
    <build>${env.BUILD_NUMBER}</build>
    <min-ambari-version>2.5.0</min-ambari-version>

    <description>Natural-language SQL workbench powered by LLM + Apache Polaris catalog.</description>

    <!--
      Main REST resource. All calls are proxied to the Python semantic service.
      URL pattern:
        /api/v1/views/SQL-ASSISTANT-VIEW/versions/1.0.0.0/instances/SQL_ASSISTANT_INSTANCE/resources/api/**
    -->
    <resource>
        <name>api</name>
        <service-class>org.apache.ambari.view.sqlassistant.resources.SqlAssistantService</service-class>
    </resource>

    <system-services>
        <service>
            <class>org.apache.ambari.view.sqlassistant.service.GsonConfigurator</class>
        </service>
    </system-services>

    <!-- ── View parameters (configurable per instance) ─────────────────── -->

    <parameter>
        <name>sql.assistant.semantic.service.url</name>
        <description>URL of the Python semantic service (FastAPI). Example: http://edge01.dev01.hadoop.clemlab.com:8090</description>
        <label>Semantic Service URL</label>
        <required>true</required>
        <default-value>http://localhost:8090</default-value>
    </parameter>

    <parameter>
        <name>sql.assistant.connect.timeout.seconds</name>
        <description>HTTP connect timeout (seconds) when calling the semantic service.</description>
        <label>Connect Timeout (s)</label>
        <required>false</required>
        <default-value>10</default-value>
    </parameter>

    <parameter>
        <name>sql.assistant.read.timeout.seconds</name>
        <description>HTTP read timeout (seconds) – set above the LLM generation timeout.</description>
        <label>Read Timeout (s)</label>
        <required>false</required>
        <default-value>180</default-value>
    </parameter>

    <parameter>
        <name>sql.assistant.working.dir</name>
        <description>Working directory on the Ambari server for view state.</description>
        <label>Working Directory</label>
        <required>false</required>
        <default-value>/var/lib/ambari-server/resources/views/work/SQL-ASSISTANT-VIEW{1.0.0.0}</default-value>
    </parameter>

    <!-- ── Default instance ────────────────────────────────────────────── -->

    <instance>
        <name>SQL_ASSISTANT_INSTANCE</name>
        <label>SQL Assistant</label>
        <description>Natural-language SQL workbench for ODP clusters</description>
        <visible>true</visible>
        <public>false</public>
        <roles>
            <role>CLUSTER.ADMINISTRATOR</role>
            <role>CLUSTER.OPERATOR</role>
            <role>SERVICE.ADMINISTRATOR</role>
            <role>SERVICE.OPERATOR</role>
            <role>CLUSTER.USER</role>
        </roles>
    </instance>

</view>
