  ],
  "description": "Modern data exploration and visualisation platform. Build dashboards and charts directly from your data warehouse.",
  "valueAliases": {},
  "requiredChartVersion": ">=0.12.29",
  "requiresContext": [
    { "capability": "oidc", "fields": ["issuerUrl", "realm"] },
    { "capability": "kerberos", "fields": ["realm"] },
    { "capability": "hive", "fields": ["hs2HostPort", "authMode"], "when": "hiveDb.enabled" }
  ],
  "securityCoupling": {
    "requireIngress": true,
    "minTlsMode": "signedByAmbariCA",
    "tlsProvisioning": "k8s-view"
  }
}
