{
  "label": "Superset",
  "chart": "apache/superset",
  "pattern": "superset-.*",
  "secretName": "registry-credentials",
  "version": "0.12.31",
  "dependencies": {
    "kerberos-keytab-mutating-webhook": {
      "fullnameOverride": "keytab-webhook",
      "secretName": "regcred",
      "chart": "kerberos-keytab-mutating-webhook",
      "chartVersion": "0.1.0",
      "imageTag": "1.0.0.1",
      "imageRepository": "registry.clemlab.com/clemlabprojects",
      "namespace": "ambari-mutating-webhooks",
      "imageGlobalRegistryProperty": "global.imageRegistry",
      "crds": [],
      "dynamicValues": [
        "AMBARI_KERBEROS_REALM:backend.krbRealm"
      ],
      "isWebhook": true,
      "serviceAccounts": [
        "kerberos-keytab-mutating-webhook"
      ]
    }
  },
  "dynamicValues": [
    "AMBARI_KERBEROS_REALM:global.security.kerberos.realm",
    "AMBARI_OIDC_REALM:global.security.auth.oidc.realm",
    "AMBARI_OIDC_ISSUER_URL:global.security.auth.oidc.issuerUrl"
  ],
  "oidc": [
    {
      "key": "superset",
      "clientIdTemplate": "{{releaseName}}-{{namespace}}",
      "secretNameTemplate": "{{releaseName}}-oidc-client",
      "redirectUriTemplate": "https://{{ingressHost}}/oauth-authorized/generic",
      "publicClient": false,
      "standardFlowEnabled": true,
      "enabled": true
    }
  ],
  "kerberos": [
    {
      "key": "service",
      "serviceName": "superset-dashboard",
      "principalTemplate": "{{service}}-{{namespace}}@{{realm}}",
      "secretNameTemplate": "{{releaseName}}-keytab",
      "keyNameInSecret": "service.keytab",
      "mountPath": "/etc/security/keytabs"
    }
  ],
  "endpoints": [
    {
      "id": "ui",
      "label": "Superset UI",
      "type": "template",
      "template": "http://{{host}}:{{port}}/",
      "properties": {
        "host": {
          "source": "template",
          "type": "string",
          "template": "{{releaseName}}-superset.{{namespace}}.svc.cluster.local"
        },
        "port": {
          "source": "helm",
          "type": "integer",
          "path": "service.port"
        }
      }
    }
  ],
  "mounts": [],
  "variables": [
    {
      "name": "trinoHost",
      "from": { "type": "form", "field": "ui_trino_host" }
    },
    {
      "name": "trinoPort",
      "from": { "type": "form", "field": "ui_trino_port" }
    },
    {
      "name": "hiveHostPort",
      "from": {
        "type": "context",
        "key": "hive.hs2HostPort",
        "enabledField": "hiveDb.enabled",
        "overrideFields": ["hiveDb.hostPort"]
      }
    },
    {
      "name": "hiveAuthMode",
      "from": {
        "type": "context",
        "key": "hive.authMode",
        "enabledField": "hiveDb.enabled",
        "overrideFields": ["hiveDb.authMode"]
      }
    },
    {
      "name": "ingressEnabled",
      "from": {
        "type": "form",
        "field": "ingress.enabled"
      }
    },
    {
      "name": "ingressClassName",
      "from": {
        "type": "form",
        "field": "ingress.ingressClassName"
      }
    },
    {
      "name": "ingressPath",
      "from": {
        "type": "form",
        "field": "ingress.path"
      }
    },
    {
      "name": "ingressHost",
      "from": {
        "type": "form",
        "field": "ingress.host"
      }
    },
    {
      "name": "ingressTLSSecret",
      "from": {
        "type": "form",
        "field": "ingress.tlsSecret"
      }
    },
    {
      "name": "ingressProxyBufferSize",
      "from": {
        "type": "form",
        "field": "ingress.tuning.proxyBufferSize"
      }
    },
    {
      "name": "ingressProxyBuffersNumber",
      "from": {
        "type": "form",
        "field": "ingress.tuning.proxyBuffersNumber"
      }
    },
    {
      "name": "ingressProxyBusyBuffersSize",
      "from": {
        "type": "form",
        "field": "ingress.tuning.proxyBusyBuffersSize"
      }
    },
    {
      "name": "ingressProxyBodySize",
      "from": {
        "type": "form",
        "field": "ingress.tuning.proxyBodySize"
      }
    },
    {
      "name": "ingressProxyReadTimeout",
      "from": {
        "type": "form",
        "field": "ingress.tuning.proxyReadTimeout"
      }
    },
    {
      "name": "ingressProxyConnectTimeout",
      "from": {
        "type": "form",
        "field": "ingress.tuning.proxyConnectTimeout"
      }
    },
    {
      "name": "ingressEnabled",
      "from": {
        "type": "form",
        "field": "ingress.enabled"
      }
    },
    {
      "name": "ingressClassName",
      "from": {
        "type": "form",
        "field": "ingress.ingressClassName"
      }
    },
    {
      "name": "ingressPath",
      "from": {
        "type": "form",
        "field": "ingress.path"
      }
    },
    {
      "name": "ingressHost",
      "from": {
        "type": "form",
        "field": "ingress.host"
      }
    },
    {
      "name": "ingressTLSSecret",
      "from": {
        "type": "form",
        "field": "ingress.tlsSecret"
      }
    },
    {
      "name": "ingressProxyBufferSize",
      "from": {
        "type": "form",
        "field": "ingress.tuning.proxyBufferSize"
      }
    },
    {
      "name": "ingressProxyBuffersNumber",
      "from": {
        "type": "form",
        "field": "ingress.tuning.proxyBuffersNumber"
      }
    },
    {
      "name": "ingressProxyBusyBuffersSize",
      "from": {
        "type": "form",
        "field": "ingress.tuning.proxyBusyBuffersSize"
      }
    },
    {
      "name": "ingressProxyBodySize",
      "from": {
        "type": "form",
        "field": "ingress.tuning.proxyBodySize"
      }
    },
    {
      "name": "ingressProxyReadTimeout",
      "from": {
        "type": "form",
        "field": "ingress.tuning.proxyReadTimeout"
      }
    },
    {
      "name": "ingressProxyConnectTimeout",
      "from": {
        "type": "form",
        "field": "ingress.tuning.proxyConnectTimeout"
      }
    },
    {
      "name": "supersetSecret",
      "from": {
        "type": "form",
        "field": "superset.secretKey"
      }
    },
    {
      "name": "supersetOpenStreetMapServerUrl",
      "from": {
        "type": "form",
        "field": "superset.openstreetmapServerUrl"
      }
    },
    {
      "name": "adminUsers",
      "from": {
        "type": "form",
        "field": "security.adminUsers"
      }
    },
    {
      "name": "adminGroups",
      "from": {
        "type": "form",
        "field": "security.adminGroups"
      }
    },
    {
      "name": "ingressCertManagerIssuerName",
      "from": {
        "type": "form",
        "field": "ingress.certManager.issuerName"
      }
    },
    {
      "name": "ingressCertManagerValidityDays",
      "from": {
        "type": "form",
        "field": "ingress.certManager.validityDays"
      }
    },
    {
      "name": "ingressExternalSecretStoreName",
      "from": {
        "type": "form",
        "field": "ingress.externalSecret.secretStoreName"
      }
    },
    {
      "name": "ingressExternalSecretRemoteKey",
      "from": {
        "type": "form",
        "field": "ingress.externalSecret.remoteKey"
      }
    },
    {
      "name": "ingressExternalSecretRefreshInterval",
      "from": {
        "type": "form",
        "field": "ingress.externalSecret.refreshInterval"
      }
    }
  ],
  "bindings": [
    {
      "name": "ingress-setup",
      "_description": "Writes the canonical ingress shape every KDPS chart accepts. The `hosts[]` entry uses the rich object form `{host, paths[]}` so OpenMetadata- and Trino-style charts work out of the box; the Superset chart's template was made shape-tolerant (accepts string OR object) in chart >= 0.12.25.",
      "targets": [
        {
          "path": "ingress.hosts[]",
          "op": "set",
          "from": {
            "type": "template",
            "template": {
              "host": "${ingressHost}",
              "paths": [
                {
                  "path": "${ingressPath}",
                  "pathType": "ImplementationSpecific"
                }
              ]
            }
          }
        },
        {
          "path": "ingress.pathType",
          "op": "set",
          "from": {
            "type": "template",
            "template": "ImplementationSpecific"
          }
        },
        {
          "path": "ingress.tls[]",
          "skipIfVarEmpty": "ingressTLSSecret",
          "op": "set",
          "from": {
            "type": "template",
            "template": {
              "secretName": "${ingressTLSSecret}",
              "hosts": [
                "${ingressHost}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "ingress-nginx-tuning",
      "_description": "Backslash-escaped dots in the leaf key — the UI binding engine (bindings.ts:pathToParts) treats backslash-dot as a literal dot so the rendered values look like `ingress.annotations: { \"nginx.ingress.kubernetes.io/proxy-buffer-size\": \"...\" }`.",
      "targets": [
        {
          "path": "ingress.annotations.nginx\\.ingress\\.kubernetes\\.io/proxy-buffer-size",
          "skipIfVarEmpty": "ingressProxyBufferSize",
          "op": "set",
          "from": {
            "type": "template",
            "template": "${ingressProxyBufferSize}"
          }
        },
        {
          "path": "ingress.annotations.nginx\\.ingress\\.kubernetes\\.io/proxy-buffers-number",
          "skipIfVarEmpty": "ingressProxyBuffersNumber",
          "op": "set",
          "from": {
            "type": "template",
            "template": "${ingressProxyBuffersNumber}"
          }
        },
        {
          "path": "ingress.annotations.nginx\\.ingress\\.kubernetes\\.io/proxy-busy-buffers-size",
          "skipIfVarEmpty": "ingressProxyBusyBuffersSize",
          "op": "set",
          "from": {
            "type": "template",
            "template": "${ingressProxyBusyBuffersSize}"
          }
        },
        {
          "path": "ingress.annotations.nginx\\.ingress\\.kubernetes\\.io/proxy-body-size",
          "skipIfVarEmpty": "ingressProxyBodySize",
          "op": "set",
          "from": {
            "type": "template",
            "template": "${ingressProxyBodySize}"
          }
        },
        {
          "path": "ingress.annotations.nginx\\.ingress\\.kubernetes\\.io/proxy-read-timeout",
          "skipIfVarEmpty": "ingressProxyReadTimeout",
          "op": "set",
          "from": {
            "type": "template",
            "template": "${ingressProxyReadTimeout}"
          }
        },
        {
          "path": "ingress.annotations.nginx\\.ingress\\.kubernetes\\.io/proxy-connect-timeout",
          "skipIfVarEmpty": "ingressProxyConnectTimeout",
          "op": "set",
          "from": {
            "type": "template",
            "template": "${ingressProxyConnectTimeout}"
          }
        }
      ]
    },
    {
      "name": "ingress-setup",
      "_description": "Writes the canonical ingress shape every KDPS chart accepts. The `hosts[]` entry uses the rich object form `{host, paths[]}` so OpenMetadata- and Trino-style charts work out of the box; the Superset chart's template was made shape-tolerant (accepts string OR object) in chart >= 0.12.25.",
      "targets": [
        {
          "path": "ingress.hosts[]",
          "op": "set",
          "from": {
            "type": "template",
            "template": {
              "host": "${ingressHost}",
              "paths": [
                {
                  "path": "${ingressPath}",
                  "pathType": "ImplementationSpecific"
                }
              ]
            }
          }
        },
        {
          "path": "ingress.pathType",
          "op": "set",
          "from": {
            "type": "template",
            "template": "ImplementationSpecific"
          }
        },
        {
          "path": "ingress.tls[]",
          "skipIfVarEmpty": "ingressTLSSecret",
          "op": "set",
          "from": {
            "type": "template",
            "template": {
              "secretName": "${ingressTLSSecret}",
              "hosts": [
                "${ingressHost}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "ingress-nginx-tuning",
      "_description": "Backslash-escaped dots in the leaf key — the UI binding engine (bindings.ts:pathToParts) treats backslash-dot as a literal dot so the rendered values look like `ingress.annotations: { \"nginx.ingress.kubernetes.io/proxy-buffer-size\": \"...\" }`.",
      "targets": [
        {
          "path": "ingress.annotations.nginx\\.ingress\\.kubernetes\\.io/proxy-buffer-size",
          "skipIfVarEmpty": "ingressProxyBufferSize",
          "op": "set",
          "from": {
            "type": "template",
            "template": "${ingressProxyBufferSize}"
          }
        },
        {
          "path": "ingress.annotations.nginx\\.ingress\\.kubernetes\\.io/proxy-buffers-number",
          "skipIfVarEmpty": "ingressProxyBuffersNumber",
          "op": "set",
          "from": {
            "type": "template",
            "template": "${ingressProxyBuffersNumber}"
          }
        },
        {
          "path": "ingress.annotations.nginx\\.ingress\\.kubernetes\\.io/proxy-busy-buffers-size",
          "skipIfVarEmpty": "ingressProxyBusyBuffersSize",
          "op": "set",
          "from": {
            "type": "template",
            "template": "${ingressProxyBusyBuffersSize}"
          }
        },
        {
          "path": "ingress.annotations.nginx\\.ingress\\.kubernetes\\.io/proxy-body-size",
          "skipIfVarEmpty": "ingressProxyBodySize",
          "op": "set",
          "from": {
            "type": "template",
            "template": "${ingressProxyBodySize}"
          }
        },
        {
          "path": "ingress.annotations.nginx\\.ingress\\.kubernetes\\.io/proxy-read-timeout",
          "skipIfVarEmpty": "ingressProxyReadTimeout",
          "op": "set",
          "from": {
            "type": "template",
            "template": "${ingressProxyReadTimeout}"
          }
        },
        {
          "path": "ingress.annotations.nginx\\.ingress\\.kubernetes\\.io/proxy-connect-timeout",
          "skipIfVarEmpty": "ingressProxyConnectTimeout",
          "op": "set",
          "from": {
            "type": "template",
            "template": "${ingressProxyConnectTimeout}"
          }
        }
      ]
    },
    {
      "name": "superset-db-connection",
      "skipIfVarEmpty": "trinoHost",
      "targets": [
        {
          "path": "extraEnv.TRINO_URL",
          "from": { "type": "template", "template": "trino://${trinoHost}:${trinoPort}" }
        }
      ]
    },
    {
      "name": "superset-hive-datasource",
      "skipIfVarEmpty": "hiveHostPort",
      "targets": [
        {
          "path": "extraConfigs",
          "op": "merge",
          "from": {
            "type": "template",
            "template": {
              "import_datasources.yaml": "databases:\n- database_name: Platform Hive\n  sqlalchemy_uri: impala://${hiveHostPort}/default\n  extra: '{\"engine_params\": {\"connect_args\": {\"auth_mechanism\": \"GSSAPI\", \"kerberos_service_name\": \"hive\", \"use_http_transport\": true, \"http_path\": \"cliservice\", \"use_ssl\": true}}}'\n  impersonate_user: true\n  allow_run_async: true\n  allow_ctas: false\n  allow_cvas: false\n  tables: []\n"
            }
          }
        }
      ]
    },
    {
      "name": "trust-proxy-headers",
      "targets": [
        {
          "path": "additionalConfigProperties[]",
          "value": "http-server.process-forwarded=true"
        }
      ]
    },
    {
      "name": "superset-secret-key",
      "skipIfVarEmpty": "supersetSecret",
      "targets": [
        {
          "path": "extraEnv.SUPERSET_SECRET_KEY",
          "from": {
            "type": "var",
            "name": "supersetSecret"
          }
        }
      ]
    },
    {
      "name": "superset-openstreetmap-server-url",
      "skipIfVarEmpty": "supersetOpenStreetMapServerUrl",
      "targets": [
        {
          "path": "extraEnv.OPENSTREETMAP_SERVER_URL",
          "from": {
            "type": "var",
            "name": "supersetOpenStreetMapServerUrl"
          }
        }
      ]
    },
    {
      "name": "mount-managed-config",
      "skipIfVarEmpty": "authConfig",
      "targets": [
        {
          "path": "extraVolumes[]",
          "value": {
            "name": "managed-config-vol",
            "secret": {
              "secretName": "${authConfig}"
            }
          }
        },
        {
          "path": "extraVolumeMounts[]",
          "value": {
            "name": "managed-config-vol",
            "mountPath": "/app/pythonpath/superset_config_custom.py",
            "subPath": "superset_config.py",
            "readOnly": true
          }
        },
        {
          "path": "configOverrides.load_custom",
          "value": "from superset_config_custom import *"
        }
      ]
    },
    {
      "name": "oidc-redirect-uri",
      "skipIfVarEmpty": "ingressHost",
      "targets": [
        {
          "path": "global.security.auth.oidc.redirectUri",
          "from": {
            "type": "template",
            "template": "https://${ingressHost}/oauth-authorized/generic"
          }
        }
      ]
    },
    {
      "name": "admin-role-mapping",
      "targets": [
        {
          "path": "global.security.adminUsers",
          "skipIfVarEmpty": "adminUsers",
          "from": {
            "type": "var",
            "name": "adminUsers"
          }
        },
        {
          "path": "global.security.adminGroups",
          "skipIfVarEmpty": "adminGroups",
          "from": {
            "type": "var",
            "name": "adminGroups"
          }
        }
      ]
    }
  ],
  "form": [
    {
      "name": "releaseName",
      "label": "release name",
      "type": "string",
      "required": true
    },
    {
      "name": "namespace",
      "label": "Namespace Kubernetes",
      "type": "string",
      "required": true,
      "defaultValue": "dashboarding"
    },
    {
      "name": "trinoConnection",
      "label": "Connect to Trino",
      "type": "k8s-discovery",
      "lookupLabel": "app.kubernetes.io/name=clemlab-trino,app.kubernetes.io/component=coordinator",
      "targetHost": "ui_trino_host",
      "targetPort": "ui_trino_port",
      "help": "Select a running Trino instance to auto-fill the host/port below. Trino discovered here is normally one deployed by an Ambari K8s view."
    },
    {
      "name": "ui_trino_host",
      "label": "Trino host",
      "type": "string",
      "excludeFromValues": true,
      "help": "Auto-filled when you pick a discovered Trino above. Set it manually if Trino was deployed outside KDPS. Leave blank to skip the Trino database connection."
    },
    {
      "name": "ui_trino_port",
      "label": "Trino port",
      "type": "number",
      "defaultValue": 8080,
      "excludeFromValues": true,
      "help": "Trino coordinator port (default 8080)."
    },
    {
      "name": "hiveDb.enabled",
      "label": "Connect to platform Hive",
      "type": "boolean",
      "defaultValue": false,
      "help": "When ON, KDPS creates a Superset database connection to the HiveServer2 of the selected Platform Context (right panel). Auth follows the context (Kerberos uses the keytab/ccache already mounted in the Superset pod)."
    },
    {
      "name": "hiveDb.hostPort",
      "label": "HiveServer2 host:port",
      "type": "context-resolved",
      "contextField": "hive.hs2HostPort",
      "condition": { "field": "hiveDb.enabled", "value": true },
      "excludeFromValues": true,
      "help": "Delivered by KDPS from the selected Platform Context. Toggle Override only to point at a specific HiveServer2."
    },
    {
      "name": "hiveDb.authMode",
      "label": "Hive authentication",
      "type": "context-resolved",
      "contextField": "hive.authMode",
      "condition": { "field": "hiveDb.enabled", "value": true },
      "excludeFromValues": true,
      "help": "Delivered by KDPS from the context (kerberos / ldap / none). The Superset Hive connection is built to match it."
    },
    {
      "name": "ingressConfig",
      "label": "HTTP(S) ingress",
      "type": "group",
      "fields": [
        {
          "name": "ingress.enabled",
          "label": "Enable Ingress",
          "type": "boolean",
          "defaultValue": true,
          "help": "Expose the service through a Kubernetes Ingress. Required when an authentication profile (OIDC / LDAP-over-SSL) is selected in Step 1 — OAuth callbacks need a public hostname and HTTPS."
        },
        {
          "name": "ingress.ingressClassName",
          "label": "Ingress class",
          "type": "string",
          "required": true,
          "defaultValue": "nginx",
          "help": "Ingress class name (e.g. 'nginx', 'openshift-default'). Leave empty for the default controller.",
          "condition": {
            "field": "ingress.enabled",
            "value": true
          }
        },
        {
          "name": "ingress.host",
          "label": "Hostname (DNS)",
          "type": "string",
          "required": true,
          "excludeFromValues": true,
          "help": "Public DNS name the ingress controller will route. e.g. service.example.com.",
          "condition": {
            "field": "ingress.enabled",
            "value": true
          }
        },
        {
          "name": "ingress.path",
          "label": "HTTP path",
          "type": "string",
          "defaultValue": "/",
          "excludeFromValues": true,
          "help": "Base path for the Ingress (usually '/').",
          "condition": {
            "field": "ingress.enabled",
            "value": true
          }
        },
        {
          "name": "ingress.tlsMode",
          "label": "TLS mode",
          "type": "select",
          "defaultValue": "signedByAmbariCA",
          "excludeFromValues": true,
          "help": "Pick how this service gets its TLS leaf. Recommended path is **Sign via cert-manager** when cert-manager is installed in the cluster (auto-renewal, standard K8s pattern). Fall back to **Sign with Company CA** (if you've uploaded one to the PKI registry) or **Sign with Ambari Internal CA** (testing only, browsers will warn). Options whose backing system isn't installed are hidden automatically. TLS is mandatory when an auth profile is selected in Step 1.",
          "options": [
            {
              "label": "Sign via cert-manager (recommended)",
              "value": "signedByClusterIssuer",
              "capability": "certManager"
            },
            {
              "label": "Source from external Secret store (Vault, ESO)",
              "value": "sourcedFromExternalSecret",
              "capability": "externalSecrets"
            },
            {
              "label": "Sign with Company CA (production)",
              "value": "signedByCompanyCA"
            },
            {
              "label": "Bring your own Secret",
              "value": "bringYourOwn"
            },
            {
              "label": "Upload cert + key",
              "value": "uploadLeaf"
            },
            {
              "label": "Sign with Ambari Internal CA (testing)",
              "value": "signedByAmbariCA"
            },
            {
              "label": "None (HTTP only — not allowed with auth)",
              "value": "none"
            }
          ],
          "condition": {
            "field": "ingress.enabled",
            "value": true
          }
        },
        {
          "name": "ingress.tlsSecret",
          "label": "Existing TLS Secret name",
          "type": "string",
          "help": "Name of a kubernetes.io/tls Secret already present in the release namespace. The chart references it via ingress.tls[].secretName.",
          "condition": {
            "field": "ingress.tlsMode",
            "value": "bringYourOwn"
          }
        },
        {
          "name": "ingress.tlsUpload.cert",
          "label": "TLS certificate (PEM, leaf + chain)",
          "type": "content",
          "language": "plaintext",
          "excludeFromValues": true,
          "help": "Paste the full chain (leaf first). Saved as tls.crt in the new Secret.",
          "condition": {
            "field": "ingress.tlsMode",
            "value": "uploadLeaf"
          }
        },
        {
          "name": "ingress.tlsUpload.key",
          "label": "TLS private key (PEM)",
          "type": "content",
          "language": "plaintext",
          "excludeFromValues": true,
          "help": "Paste the private key matching the certificate above. Saved as tls.key.",
          "condition": {
            "field": "ingress.tlsMode",
            "value": "uploadLeaf"
          }
        },
        {
          "name": "ingress.tlsUpload.secretName",
          "label": "Target Secret name",
          "type": "string",
          "excludeFromValues": true,
          "help": "Name of the kubernetes.io/tls Secret the view will create from the uploaded cert/key. Leave blank to use the default `<releaseName>-ingress-tls` (computed server-side at deploy time).",
          "condition": {
            "field": "ingress.tlsMode",
            "value": "uploadLeaf"
          }
        },
        {
          "name": "ingress.tlsSelfSign.caName",
          "label": "Company CA",
          "type": "secret-discovery",
          "lookupLabel": "ambari.clemlab.com/resource-type=issuing-ca",
          "excludeFromValues": true,
          "help": "Pick a Company Issuing CA from the PKI registry. The view mints a leaf TLS cert signed by this CA before installing the chart. CAs are stored as Kubernetes Secrets in the `ambari-pki` namespace labeled `ambari.clemlab.com/resource-type=issuing-ca`. Upload CAs via Cluster security → Certificate Authorities.",
          "condition": {
            "field": "ingress.tlsMode",
            "value": "signedByCompanyCA"
          }
        },
        {
          "name": "ingress.tlsSelfSign.validityDays",
          "label": "Leaf validity (days)",
          "type": "string",
          "defaultValue": "90",
          "excludeFromValues": true,
          "help": "How long the minted leaf certificate is valid. Capped server-side at 825 (CA/Browser Forum baseline).",
          "condition": {
            "field": "ingress.tlsMode",
            "value": [
              "signedByAmbariCA",
              "signedByCompanyCA"
            ]
          }
        },
        {
          "name": "ingress.certManager.issuerName",
          "label": "ClusterIssuer",
          "type": "cluster-issuer-discovery",
          "excludeFromValues": true,
          "help": "Pick a cert-manager ClusterIssuer or Issuer. The view writes a Certificate resource pre-install; cert-manager mints the Secret and auto-renews it before expiry.",
          "condition": {
            "field": "ingress.tlsMode",
            "value": "signedByClusterIssuer"
          }
        },
        {
          "name": "ingress.certManager.validityDays",
          "label": "Leaf validity (days)",
          "type": "string",
          "defaultValue": "90",
          "excludeFromValues": true,
          "help": "Validity in days. Translated to durationHours on the Certificate resource. cert-manager renews at duration/6 before expiry.",
          "condition": {
            "field": "ingress.tlsMode",
            "value": "signedByClusterIssuer"
          }
        },
        {
          "name": "ingress.externalSecret.secretStoreName",
          "label": "SecretStore",
          "type": "secret-store-discovery",
