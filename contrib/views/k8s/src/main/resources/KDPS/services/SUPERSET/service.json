        },
        {
          "name": "ingress.externalSecret.remoteKey",
          "label": "Remote key / path",
          "type": "string",
          "excludeFromValues": true,
          "help": "Path/key in the upstream store. For Vault PKI: 'pki/issue/<role>'. For Vault KV: 'secret/data/tls/<name>'. For AWS Secrets Manager: the secret name.",
          "condition": {
            "field": "ingress.tlsMode",
            "value": "sourcedFromExternalSecret"
          }
        },
        {
          "name": "ingress.externalSecret.refreshInterval",
          "label": "Refresh interval",
          "type": "string",
          "defaultValue": "1h",
          "excludeFromValues": true,
          "help": "ESO refresh cadence. e.g. '1h', '15m', '0' (no periodic refresh).",
          "condition": {
            "field": "ingress.tlsMode",
            "value": "sourcedFromExternalSecret"
          }
        },
        {
          "name": "ingressTuning",
          "label": "Ingress tuning (nginx)",
          "type": "group",
          "condition": {
            "field": "ingress.enabled",
            "value": true
          },
          "fields": [
            {
              "name": "ingress.tuning.proxyBufferSize",
              "label": "proxy-buffer-size",
              "type": "string",
              "excludeFromValues": true,
              "help": "nginx.ingress.kubernetes.io/proxy-buffer-size. Leave blank to use chart default (16k under OIDC/OAuth, otherwise nginx default 4k/8k). Bump if you see 502 + 'upstream sent too big header' on OAuth callbacks."
            },
            {
              "name": "ingress.tuning.proxyBuffersNumber",
              "label": "proxy-buffers-number",
              "type": "string",
              "excludeFromValues": true,
              "help": "nginx.ingress.kubernetes.io/proxy-buffers-number. Total response buffers = number × size."
            },
            {
              "name": "ingress.tuning.proxyBusyBuffersSize",
              "label": "proxy-busy-buffers-size",
              "type": "string",
              "excludeFromValues": true,
              "help": "nginx.ingress.kubernetes.io/proxy-busy-buffers-size. Should be ≥ proxy-buffer-size and ≤ total buffer capacity."
            },
            {
              "name": "ingress.tuning.proxyBodySize",
              "label": "proxy-body-size",
              "type": "string",
              "excludeFromValues": true,
              "help": "nginx.ingress.kubernetes.io/proxy-body-size. Maximum request body the proxy accepts (e.g. '64m'). Bump for large uploads / file imports."
            },
            {
              "name": "ingress.tuning.proxyReadTimeout",
              "label": "proxy-read-timeout (seconds)",
              "type": "string",
              "excludeFromValues": true,
              "help": "nginx.ingress.kubernetes.io/proxy-read-timeout. Bump for long-running queries (Trino, Superset). Default 60."
            },
            {
              "name": "ingress.tuning.proxyConnectTimeout",
              "label": "proxy-connect-timeout (seconds)",
              "type": "string",
              "excludeFromValues": true,
              "help": "nginx.ingress.kubernetes.io/proxy-connect-timeout. Time the proxy waits when opening a connection to the backend pod."
            }
          ],
          "collapsed": true,
          "help": "Advanced — usually leave blank. nginx ingress annotations (proxy buffers / timeouts). Chart-side defaults are sensible for the common case; expand if you need to override (large headers on OAuth, long-running queries, big uploads)."
        }
      ]
    },
    {
      "name": "superset",
