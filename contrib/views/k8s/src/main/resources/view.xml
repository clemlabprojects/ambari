<view>
    <name>K8S-VIEW</name>
    <label>Ambari K8S View</label>
    <version>1.0.0.6</version>
    <build>${env.BUILD_NUMBER}</build>
    <min-ambari-version>2.5.0</min-ambari-version>

    <description>Une vue Ambari pour interagir avec un cluster Kubernetes.</description>
    
    <!--
      Déclaration de notre service REST. Le nom 'api' sera utilisé dans l'URL.
      Exemple: /api/v1/views/K8S_VIEW/versions/1.0.0.0/instances/K8S_VIEW_INSTANCE/resources/api/cluster/stats
    -->
    <resource>
        <name>api</name>
        <service-class>org.apache.ambari.view.k8s.KubeService</service-class>
    </resource>
    
    <system-services>
        <service>
          <class>org.glassfish.jersey.media.multipart.MultiPartFeature</class>
        </service>
        <service>
          <class>org.apache.ambari.view.k8s.service.GsonConfigurator</class>
        </service>
        <service>
          <class>org.apache.ambari.view.k8s.resources.ArgoResource</class>
        </service>
    </system-services>
    <parameter>
        <name>k8s.view.working.dir</name>
        <description>Le répertoire sur le serveur Ambari où stocker les fichiers de configuration de la vue.</description>
        <label>Répertoire de Travail</label>
        <required>false</required>
        <default-value>/var/lib/ambari-server/resources/views/work/K8S-VIEW{1.0.0.5}</default-value>
    </parameter>
    <parameter>
        <name>ambari.cluster.discovery.enabled</name>
        <description>Auto discovery of existing cluster from ambari-server.</description>
        <label>Cluster Auto Discovery</label>
        <required>false</required>
        <default-value>true</default-value>
    </parameter>
    <parameter>
        <name>view.admin.users</name>
        <description>Comma-separated list of Ambari usernames allowed to configure the view (upload kubeconfig, manage repos). When left empty, any user with access to the view instance may configure it.</description>
        <label>View Admin Users</label>
        <required>false</required>
    </parameter>
    <parameter>
        <name>view.operator.users</name>
        <description>Comma-separated list of Ambari usernames with operator (write) access — may deploy/destroy releases but cannot change view configuration.</description>
        <label>View Operator Users</label>
        <required>false</required>
    </parameter>

    <persistence>
        <!-- Fully qualified name of your @Entity class -->
        <entity>
          <class>org.apache.ambari.view.k8s.store.HelmRepoEntity</class>
          <id-property>id</id-property>
        </entity>
        <entity>
          <class>org.apache.ambari.view.k8s.store.K8sReleaseEntity</class>
          <id-property>id</id-property>
        </entity>
        <entity>
          <class>org.apache.ambari.view.k8s.store.CommandStatusEntity</class>
          <id-property>id</id-property>
        </entity>
        <entity>
            <class>org.apache.ambari.view.k8s.store.CommandEntity</class>
            <id-property>id</id-property>
        </entity>
        <entity>
            <class>org.apache.ambari.view.k8s.store.SecurityProfileEntity</class>
            <id-property>id</id-property>
        </entity>
        <entity>
            <class>org.apache.ambari.view.k8s.store.SecurityMappingEntity</class>
            <id-property>id</id-property>
        </entity>
        <!-- If more entities are added later, list them here as well -->
        <!-- <entity class="org.apache.ambari.view.k8s.store.OtherEntity"/> -->
    </persistence>
    <!--
      Définition d'une instance par défaut.
      Contrairement à la vue Capacity Scheduler, nous n'utilisons pas <auto-instance>
      car notre vue ne dépend pas d'un service géré par Ambari (comme YARN).
      Une création manuelle est plus appropriée.
    -->
    <instance>
        <name>K8S_VIEW_INSTANCE</name>
        <label>Kubernetes Cluster Manager</label>
        <description>Instance par défaut pour la vue Kubernetes</description>
        <visible>true</visible>
        <public>false</public>
        <roles>
            <role>CLUSTER.ADMINISTRATOR</role>
            <role>CLUSTER.OPERATOR</role>
            <role>SERVICE.ADMINISTRATOR</role>
            <role>SERVICE.OPERATOR</role>
            <role>CLUSTER.USER</role>
        </roles>
    </instance>
    
</view>
